# ─── PHASE 1: Required from start ───────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ─── PHASE 3: Groq LLM ──────────────────────────────────────────────────────
# Get free at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ─── PHASE 2: GitHub Integration ─────────────────────────────────────────────
# Create a GitHub Personal Access Token with repo scope
GITHUB_TOKEN=ghp_your_github_token_here
# Set this as your webhook secret in GitHub App/repo settings
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here

# ─── PHASE 5: Database + RAG ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codereview
# For Docker Compose:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/codereview

# ─── OPTIONAL: Observability ─────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__your_key_here
LANGSMITH_PROJECT=codereview-agent

# ─── GCP (Phase 9 only) ──────────────────────────────────────────────────────
# GCP_PROJECT_ID=your-project-id
# CLOUD_RUN_REGION=us-central1
